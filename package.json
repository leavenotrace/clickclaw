{
  "name": "clickclaw",
  "version": "0.1.5",
  "description": "ClickClaw — 点击即装的 OpenClaw 桌面管理工具",
  "main": "./out/main/index.js",
  "author": "ClickClaw Team",
  "license": "GPL-3.0",
  "homepage": "https://clickclaw.cn",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npm run lint:eslint && npm run typecheck",
    "lint:eslint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc -b tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js}\"",
    "i18n:check": "node scripts/check-i18n.js",
    "i18n:check:unused": "node scripts/check-i18n.js --unused",
    "release:check-version": "node scripts/check-release-version.js",
    "test:release-rewrite": "node scripts/test-rewrite-latest-yml.js",
    "postinstall": "electron-builder install-app-deps",
    "package:resources": "node scripts/package-resources.js",
    "package:resources:win:x64": "node scripts/package-resources.js --platform win32 --arch x64",
    "package:resources:win:arm64": "node scripts/package-resources.js --platform win32 --arch arm64",
    "package:resources:mac:arm64": "node scripts/package-resources.js --platform darwin --arch arm64",
    "package:resources:mac:x64": "node scripts/package-resources.js --platform darwin --arch x64",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "dist:win:x64": "npm run package:resources:win:x64 && npm run build && electron-builder --win --x64",
    "dist:win:arm64": "npm run package:resources:win:arm64 && npm run build && electron-builder --win --arm64",
    "dist:mac:arm64": "npm run package:resources:mac:arm64 && npm run build && electron-builder --mac --arm64",
    "dist:mac:x64": "npm run package:resources:mac:x64 && npm run build && electron-builder --mac --x64"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/x": "^2.3.0",
    "@ant-design/x-markdown": "^2.3.0",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "antd": "^6.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "i18next": "^25.0.0",
    "json5": "^2.2.3",
    "react-i18next": "^15.0.0",
    "react-markdown": "^9.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "isbinaryfile": "^5.0.7"
  }
}
